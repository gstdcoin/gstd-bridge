# GSTD Bridge Validator — Environment Variables
# Copy to .env and fill in your values before starting.

# ── Chain RPC endpoints ────────────────────────────────────────────────────
TON_RPC_URL=https://toncenter.com/api/v2
TON_API_KEY=                      # Optional: toncenter API key (higher rate limits)

SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

XRPL_WS_URL=wss://xrplcluster.com

# ── Vault addresses (set after deploying contracts) ────────────────────────
TON_VAULT_ADDRESS=EQDv6cYW9nNiKjN3Nwl8D6ABjUiH1gYfWVGZhfP7-9tZskTO
SOL_VAULT_ADDRESS=AzN7uPhQZgThxsRvhNGHPUPRjdEjScTbqQdf5gt6Fqby
XRP_VAULT_ADDRESS=ryHSvxUqpcTjoESHbCkMJoqzenjFgPQSf

# ── MPC config ─────────────────────────────────────────────────────────────
# share_index: this validator's index (0-based, must be unique per validator)
# threshold: min signatures needed (e.g. 2 of 3)
MPC_SHARE_INDEX=0
MPC_THRESHOLD=2
MPC_TOTAL_PARTIES=3

# ── Logging ────────────────────────────────────────────────────────────────
RUST_LOG=info,gstd_bridge=debug

# ── GSTD Platform (for heartbeat) ─────────────────────────────────────────
GSTD_PLATFORM_URL=https://app.gstdtoken.com
GSTD_NODE_ID=                     # auto-generated on first run if blank
